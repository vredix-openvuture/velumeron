#!/usr/bin/env bash
# Vutureland launcher
_DIR="$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")" && pwd)"

# ── quickshell subcommand ────────────────────────────────────────────────────
# vutureland quickshell            → start/restart the QuickShell bar
# vutureland quickshell --gui-panel → toggle the GUI panel in the running instance
if [[ "${1:-}" == "quickshell" ]]; then
    shift
    case "${1:-}" in
        --gui-panel)
            touch /tmp/vutureland-qs-gui-panel
            if ! pgrep -x quickshell > /dev/null 2>&1; then
                bash "$_DIR/../assets/scripts/launch-quickshell.sh"
            fi
            exit 0
            ;;
        *)
            exec bash "$_DIR/../assets/scripts/launch-quickshell.sh"
            ;;
    esac
fi

# ── keybind-help overlay ─────────────────────────────────────────────────────
if [[ "$1" == "--keybind-help" ]]; then
    exec env LD_PRELOAD=/usr/lib/libgtk4-layer-shell.so \
        python3 "$_DIR/../gui/keybind_help.py" "${2:-}"
fi

# When starting as daemon, also start the notification daemon in the background.
for _a in "$@"; do
    if [[ "$_a" == "-d" || "$_a" == "--daemon" ]]; then
        env LD_PRELOAD=/usr/lib/libgtk4-layer-shell.so \
            python3 "$_DIR/../gui/main.py" --notify --daemon &>/dev/null &
        break
    fi
done

exec env LD_PRELOAD=/usr/lib/libgtk4-layer-shell.so \
    python3 "$_DIR/../gui/main.py" "$@"
