#!/usr/bin/env bash
# Velumeron launcher.
# The shell (bar, OSD, notifications, settings, keybind help) is now QuickShell;
# the old Python GUI / waybar / swaync are retired. This stays as the stable entry
# point and routes the legacy flags to the running QuickShell instance over IPC.
_DIR="$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")" && pwd)"
QS_DIR="${VELUMERON_DIR:-$_DIR/..}/quickshell"

# Fire-and-forget IPC into the running shell (no-op if it isn't up yet).
ipc() { qs -p "$QS_DIR" ipc call "$@" >/dev/null 2>&1 || true; }

case "${1:-}" in
    # ── quickshell control ──────────────────────────────────────────────────
    quickshell)
        shift
        case "${1:-}" in
            --gui-panel)
                touch /tmp/velumeron-qs-gui-panel
                pgrep -x quickshell >/dev/null 2>&1 || bash "$_DIR/../assets/scripts/launch-quickshell.sh"
                ;;
            *)  exec bash "$_DIR/../assets/scripts/launch-quickshell.sh" ;;
        esac
        ;;

    # ── keybind cheatsheet (quickshell overlay) ─────────────────────────────
    # velumeron --keybind-help [window|apps|system]   (no arg → full reference)
    --keybind-help)
        case "${2:-}" in
            window|apps|system) ipc keybind "$2" ;;
            *)                  ipc keybind all  ;;
        esac
        ;;

    # ── settings / notifications toggles ────────────────────────────────────
    -t|--toggle|--settings) ipc menu toggle ;;     # settings corner menu
    --panel-toggle)         ipc notify toggle ;;   # notification centre
    --dnd)                  ipc notify dnd ;;       # toggle do-not-disturb

    # ── onboarding: force the wizard / update report ─────────────────────────
    # velumeron --onboarding          first-run wizard (writes real config!)
    # velumeron --onboarding update   changelog report for the current release
    # (also available as the standalone `velumeron-welcome` command)
    --onboarding|--welcome)
        case "${2:-}" in
            update) ipc onboarding update ;;
            close)  ipc onboarding close ;;
            *)      ipc onboarding open ;;
        esac
        ;;

    # ── everyday actions (thin wrappers over the shipped scripts) ────────────
    --lock)   exec bash "${VELUMERON_DIR:-$_DIR/..}/assets/scripts/launch-hyprlock.sh" ;;
    --wallpaper)
        case "${2:-}" in
            random|"") exec bash "${VELUMERON_DIR:-$_DIR/..}/assets/scripts/wallpaper-random.sh" ;;
            *)         exec bash "${VELUMERON_DIR:-$_DIR/..}/assets/scripts/wallpaper-set.sh" --no-showcase "$2" ;;
        esac
        ;;
    --mode)
        case "${2:-}" in
            dark|light) exec bash "${VELUMERON_DIR:-$_DIR/..}/assets/scripts/apply-app-theme.sh" mode "$2" ;;
            *)          echo "usage: velumeron --mode dark|light" >&2; exit 2 ;;
        esac
        ;;

    # ── whole-session services: start / stop everything we own ───────────────
    # start → daemons (hypridle, nm-applet, polkit, keyring, brightness,
    #         clipvault, float-cascade) + the QuickShell shell. Idempotent.
    # end   → tears all of the above down. Same single source of truth that
    #         hypr.lua autostart uses, so the two never drift.
    start)   exec bash "${VELUMERON_DIR:-$_DIR/..}/assets/scripts/velumeron-services.sh" start ;;
    restart) exec bash "${VELUMERON_DIR:-$_DIR/..}/assets/scripts/velumeron-services.sh" restart ;;
    status)  exec bash "${VELUMERON_DIR:-$_DIR/..}/assets/scripts/velumeron-services.sh" status ;;

    # ── daemon: no-op — the shell starts everything via launch-shell.sh ──────
    -d|--daemon) : ;;

    # ── stop the whole session (shell + all our daemons) ─────────────────────
    end|-e|--end) exec bash "${VELUMERON_DIR:-$_DIR/..}/assets/scripts/velumeron-services.sh" stop ;;

    -h|--help)
        cat <<'EOF'
velumeron — Hyprland desktop shell launcher

  velumeron start                 Start ALL Velumeron services (daemons + shell)
  velumeron end                   Stop ALL Velumeron services
  velumeron restart               Restart everything
  velumeron status                Show which services are up
  velumeron quickshell            Start / restart only the QuickShell shell
  velumeron quickshell --gui-panel Toggle the GUI panel
  velumeron --keybind-help [ctx]  Keybind cheatsheet (ctx: window|apps|system)
  velumeron -t, --toggle          Toggle the settings menu
  velumeron --panel-toggle        Toggle the notification centre
  velumeron --dnd                 Toggle do-not-disturb
  velumeron --onboarding [update] Open the setup wizard / update report
                                  (also: velumeron-welcome)
  velumeron --lock                Lock the screen (hyprlock)
  velumeron --wallpaper [FILE]    Set a wallpaper (no arg / 'random' → random)
  velumeron --mode dark|light     Desktop-wide dark/light appearance
  velumeron -e, --end             Stop ALL Velumeron services (alias of 'end')
EOF
        ;;

    # ── no args → open the settings menu ────────────────────────────────────
    "") ipc menu toggle ;;

    *)  echo "velumeron: unknown option '$1' (try --help)" >&2; exit 1 ;;
esac
