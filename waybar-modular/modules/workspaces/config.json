{
  "hyprland/workspaces": {
    "ignore-workspaces": ["99","111","112"],
    "format-icons": {},
    "disable-scroll": false,
    "format": "{icon}",
    "on-click": "bash -c 'n=\"{name}\"; [[ \"$n\" =~ ^[0-9]+$ ]] && hyprctl dispatch workspace \"$n\"'",
    "on-scroll-up": "hyprctl dispatch workspace e-1",
    "on-scroll-down": "hyprctl dispatch workspace e+1"
  }
}
