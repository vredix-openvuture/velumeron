{
  "ignore-gtk-theme": true,
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "layer-shell-cover-screen": true,
  "cssPriority": "user",

  "control-center-margin-top":      200,
  "control-center-margin-bottom":   0,
  "control-center-margin-right":    0,
  "control-center-margin-left":     0,

  "notification-2fa-action": true,
  "notification-inline-replies": false,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,

  "timeout": 10,
  "timeout-low": 5,
  "timeout-critical": 30,

  "fit-to-screen": true,
  "relative-timestamps": true,
  "control-center-width": 444,
  "notification-window-width": 344,
  "keyboard-shortcuts": true,
  "notification-grouping": true,
  "image-visibility": "when-available",
  "transition-time": 40,
  "hide-on-clear": false,
  "hide-on-action": true,
  "text-empty": "> no data <",
  "script-fail-notify": true,

  "scripts": {
    "example-script": {
      "exec": "echo 'Do something...'",
      "urgency": "Normal"
    }
  },

  "widgets": [
    "buttons-grid",
    "volume",
    "inhibitors",
    "title",
    "notifications",
    "mpris"
  ],
  "widget-config": {
    "notifications": {
      "vexpand": true
    },
    "inhibitors": {
      "text": "INHIBITORS",
      "button-text": "CLEAR",
      "clear-all-button": true
    },
    "title": {
      "text": "> NOTIFICATIONS <",
      "clear-all-button": true,
      "button-text": "CLEAR ALL"
    },
    "dnd": {
      "text": "DO NOT DISTURB"
    },
    "label": {
      "max-lines": 5,
      "text": "Label Text"
    },
    "mpris": {
      "blacklist": [],
      "autohide": false,
      "show-album-art": "always",
      "loop-carousel": true,
      "image-size": 120,
      "image-radius": 500
    },
    "buttons-grid": {
      "buttons-per-row": 5,
      "actions": [
        {
          "label": "  ",
          "type": "toggle",
          "active": true,
          "command": "~/.config/vutureland/rofi/assets/session-menu.sh",
          "update-command": ""
        },
        {
          "label": "1",
          "type": "toggle",
          "active": true,
          "command": "",
          "update-command": ""
        },
        {
          "label": "  ",
          "type": "toggle",
          "active": true,
          "command": "~/.config/vutureland/rofi/assets/session-menu.sh",
          "update-command": ""
        },
        {
          "label": " 󰂯 ",
          "type": "toggle",
          "active": true,
          "command": "~/.config/vutureland/rofi/assets/bluetooth.sh",
          "update-command": ""
        },
        {
          "label": "  ",
          "type": "toggle",
          "active": true,
          "command": "python ~/.config/vutureland/gui/main.py",
          "update-command": ""
        }
      ]
    },
    "volume": {
      "label": "",
        "show-per-app": true,
        "show-per-app-icon": true,
        "show-per-app-label":true
    }
  }
}
