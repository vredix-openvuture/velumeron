# Device-specific – generated by hyprland.sh, not synced
hypr/user_settings.conf
hypr.lua/user_settings.lua

# Auto-generated colors (written by wallust on wallpaper change).
# These files are committed with default values as fallback templates so
# Hyprland/Waybar can start before the first wallpaper has been applied.
# The actual runtime versions live in ~/.config/vutureland/ — created by
# welcome_to_vutureland.sh on first run.
# (kept tracked: assets/colors_gtk.css, kitty/colors.conf,
#  rofi/assets/colors.rasi, assets/colors_hyprland.conf)
# colors.lua is NOT tracked — it kept showing machine-specific churn; hyprland.lua
# loads it via a guarded _try_dofile and welcome_to_vutureland.sh regenerates it.
hypr.lua/colors.lua

# Per-user GUI preferences
gui/settings.json

# Editor / IDE
.vscode/
.claude/

# Image editor backups
assets/icons/.*.png

# Auto-generated Waybar output (rebuilt by waybar.sh --rebuild)
waybar-modular/output/

# Node modules (panel)
panel/node_modules/

# Wallpapers — kept local only, never in git (large, per-user content)
assets/wallpaper/

# Logs and cache
**/*.log
**/.cache/
gui/__pycache__/
gui/models/__pycache__/
gui/pages/__pycache__/

# Wallpaper sets are per-client now (stored in ~/.config/vutureland/assets/sets.json)
assets/wallpaper/sets.json

# Archive
.archive/

