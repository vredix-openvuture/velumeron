# Device-specific – generated by hyprland.sh, not synced
hypr/user_settings.conf
hypr.lua/user_settings.lua

# Auto-generated colors (written by wallust on wallpaper change).
# These files are committed with default values as fallback templates so
# Hyprland/Waybar can start before the first wallpaper has been applied.
# The actual runtime versions live in ~/.config/velumeron/ — created by
# welcome_to_velumeron.sh on first run.
# (kept tracked: assets/colors_gtk.css, kitty/colors.conf,
#  rofi/assets/colors.rasi, assets/colors_hyprland.conf)
# colors.lua is NOT tracked — it kept showing machine-specific churn; hyprland.lua
# loads it via a guarded _try_dofile and welcome_to_velumeron.sh regenerates it.
hypr.lua/colors.lua

# Editor / IDE
.vscode/
.claude/

# Image editor backups
assets/icons/.*.png

# Node modules (panel)
panel/node_modules/

# Wallpapers — kept local only, never in git (large, per-user content).
# Exceptions: the hyprlock theme assets (the shipped lockscreen themes
# reference them — without these, clients lock to a bare background) and
# theme-names.txt (read by rofi-wallpaper.sh). `dir/*` instead of `dir/`
# because git cannot re-include below an excluded directory.
assets/wallpaper/*
!assets/wallpaper/hyprlock/
!assets/wallpaper/theme-names.txt
# The branded default wallpaper ships too (welcome_to_velumeron.sh sets it on
# first run); everything else in horizontal/ and all of vertical/ stays local.
!assets/wallpaper/horizontal/
assets/wallpaper/horizontal/*
!assets/wallpaper/horizontal/velumeron_with_raven.png

# Logs and cache
**/*.log
**/.cache/

# Wallpaper sets are per-client now (stored in ~/.config/velumeron/assets/sets.json)
assets/wallpaper/sets.json

# Compiled QML plugins — CMake build tree + generated module output.
# Source lives in quickshell/plugins/<name>/; the .so module is rebuilt on demand
# by assets/scripts/build-mpv-plugin.sh (invoked from launch-quickshell.sh).
quickshell/plugins/*/build/
quickshell/plugins/Velumeron/

# Archive
.archive/

__pycache__/
